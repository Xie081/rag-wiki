# Environment variables for local development
# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# DeepSeek API Key (required for AI features — get one at https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# JWT Secret (use a long random string)
JWT_SECRET=generate-a-random-secret-key-at-least-256-bits

# PostgreSQL connection (defaults shown below)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/rag_wiki
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres
